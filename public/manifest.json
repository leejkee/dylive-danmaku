{
  "manifest_version": 3,
  "name": "Douyin danmaku tool",
  "version": "1.0",
  "description": "A Chrome extension to capture danmaku from Douyin live streams.",
  "permissions": [],
  "host_permissions": [
    "*://live.douyin.com/*"
  ],
  "background": {
    "service_worker": "background/background.js"
  },
  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "Douyin danmaku tool"
  },
  "content_scripts": [
    {
      "matches": [
        "*://live.douyin.com/*"
      ],
      "js": [
        "content-scripts/content.js"
      ],
      "run_at": "document_start"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "inject-scripts/inject.js"
      ],
      "matches": [
        "*://live.douyin.com/*"
      ]
    }
  ]
}